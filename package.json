{
  "name": "billing-solution",
  "private": false,
  "version": "1.3.1",
  "description": "Billing Solution - Offline-first Point of Sale Desktop App",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:build": "node scripts/electron-build-release.cjs",
    "electron:build:all": "node scripts/electron-build-release.cjs",
    "electron:build:mac": "vite build && electron-builder --mac --publish never",
    "electron:build:win": "vite build && electron-builder --win --publish never",
    "electron:build:linux": "vite build && electron-builder --linux --publish never",
    "verify": "npm run build",
    "verify:full": "npm run lint && npm run build"
  },
  "build": {
    "appId": "com.billing.solution",
    "productName": "Billing Solution",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "public/icon-512.png",
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon-512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon-512.png"
    },
    "publish": {
      "provider": "github",
      "owner": "tmahajan90",
      "repo": "billing-solution"
    }
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "electron-updater": "^6.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
